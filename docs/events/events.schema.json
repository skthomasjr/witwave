{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/skthomasjr/autonomous-agent/docs/events/events.schema.json",
  "title": "Witwave event stream envelope and per-type payloads",
  "description": "Phase-1 event types for GET /events/stream on the harness. See ./README.md for wire format and rationale.",
  "type": "object",
  "required": ["type", "version", "id", "ts", "agent_id", "payload"],
  "additionalProperties": true,
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "job.fired",
        "task.fired",
        "heartbeat.fired",
        "continuation.fired",
        "trigger.fired",
        "webhook.delivered",
        "webhook.failed",
        "hook.decision",
        "a2a.request.received",
        "a2a.request.completed",
        "agent.lifecycle",
        "conversation.turn",
        "conversation.chunk",
        "tool.use",
        "trace.span",
        "stream.gap",
        "stream.overrun"
      ]
    },
    "version": { "type": "integer", "minimum": 1 },
    "id": { "type": "string", "minLength": 1 },
    "ts": { "type": "string", "format": "date-time" },
    "agent_id": { "type": ["string", "null"] },
    "payload": { "type": "object" }
  },
  "allOf": [
    { "if": { "properties": { "type": { "const": "job.fired" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/JobFired" } } } },
    { "if": { "properties": { "type": { "const": "task.fired" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/TaskFired" } } } },
    { "if": { "properties": { "type": { "const": "heartbeat.fired" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/HeartbeatFired" } } } },
    { "if": { "properties": { "type": { "const": "continuation.fired" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/ContinuationFired" } } } },
    { "if": { "properties": { "type": { "const": "trigger.fired" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/TriggerFired" } } } },
    { "if": { "properties": { "type": { "const": "webhook.delivered" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/WebhookDelivered" } } } },
    { "if": { "properties": { "type": { "const": "webhook.failed" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/WebhookFailed" } } } },
    { "if": { "properties": { "type": { "const": "hook.decision" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/HookDecision" } } } },
    { "if": { "properties": { "type": { "const": "a2a.request.received" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/A2ARequestReceived" } } } },
    { "if": { "properties": { "type": { "const": "a2a.request.completed" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/A2ARequestCompleted" } } } },
    { "if": { "properties": { "type": { "const": "agent.lifecycle" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/AgentLifecycle" } } } },
    { "if": { "properties": { "type": { "const": "conversation.turn" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/ConversationTurn" } } } },
    { "if": { "properties": { "type": { "const": "conversation.chunk" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/ConversationChunk" } } } },
    { "if": { "properties": { "type": { "const": "tool.use" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/ToolUse" } } } },
    { "if": { "properties": { "type": { "const": "trace.span" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/TraceSpan" } } } },
    { "if": { "properties": { "type": { "const": "stream.gap" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/StreamGap" } } } },
    { "if": { "properties": { "type": { "const": "stream.overrun" } } },
      "then": { "properties": { "payload": { "$ref": "#/$defs/StreamOverrun" } } } }
  ],
  "$defs": {
    "Outcome": { "type": "string", "enum": ["success", "error", "timeout", "skipped"] },
    "JobFired": {
      "type": "object",
      "required": ["name", "schedule", "duration_ms", "outcome"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "schedule": { "type": "string" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "outcome": { "$ref": "#/$defs/Outcome" },
        "error": { "type": "string" }
      }
    },
    "TaskFired": {
      "type": "object",
      "required": ["name", "duration_ms", "outcome"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "window": { "type": "string" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "outcome": { "$ref": "#/$defs/Outcome" },
        "error": { "type": "string" }
      }
    },
    "HeartbeatFired": {
      "type": "object",
      "required": ["duration_ms", "outcome"],
      "additionalProperties": true,
      "properties": {
        "schedule": { "type": "string" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "outcome": { "$ref": "#/$defs/Outcome" },
        "error": { "type": "string" }
      }
    },
    "ContinuationFired": {
      "type": "object",
      "required": ["name", "upstream_kind", "upstream_name", "duration_ms", "outcome"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "upstream_kind": { "type": "string", "enum": ["job", "task", "trigger", "a2a", "continuation"] },
        "upstream_name": { "type": "string" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "outcome": { "$ref": "#/$defs/Outcome" },
        "error": { "type": "string" }
      }
    },
    "TriggerFired": {
      "type": "object",
      "required": ["name", "endpoint", "duration_ms", "outcome"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "endpoint": { "type": "string" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "outcome": { "$ref": "#/$defs/Outcome" },
        "error": { "type": "string" }
      }
    },
    "WebhookDelivered": {
      "type": "object",
      "required": ["name", "url_host", "status_code", "duration_ms"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "url_host": { "type": "string" },
        "status_code": { "type": "integer", "minimum": 100, "maximum": 599 },
        "duration_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "WebhookFailed": {
      "type": "object",
      "required": ["name", "url_host", "reason", "duration_ms"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "url_host": { "type": "string" },
        "reason": { "type": "string", "enum": ["timeout", "dns_denied", "http_error", "exception"] },
        "status_code": { "type": "integer", "minimum": 100, "maximum": 599 },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "error": { "type": "string" }
      }
    },
    "HookDecision": {
      "type": "object",
      "required": ["backend", "session_id_hash", "tool", "decision"],
      "additionalProperties": true,
      "properties": {
        "backend": { "type": "string", "enum": ["claude", "codex", "gemini"] },
        "session_id_hash": { "type": "string", "minLength": 1 },
        "tool": { "type": "string" },
        "decision": { "type": "string", "enum": ["allow", "deny", "warn"] },
        "rule_id": { "type": "string" },
        "reason": { "type": "string" }
      }
    },
    "A2ARequestReceived": {
      "type": "object",
      "required": ["concern"],
      "additionalProperties": true,
      "properties": {
        "concern": { "type": "string", "enum": ["a2a", "heartbeat", "job", "task", "trigger", "continuation"] },
        "model": { "type": "string" }
      }
    },
    "A2ARequestCompleted": {
      "type": "object",
      "required": ["concern", "outcome", "duration_ms"],
      "additionalProperties": true,
      "properties": {
        "concern": { "type": "string", "enum": ["a2a", "heartbeat", "job", "task", "trigger", "continuation"] },
        "outcome": { "$ref": "#/$defs/Outcome" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "error": { "type": "string" }
      }
    },
    "AgentLifecycle": {
      "type": "object",
      "required": ["backend", "event"],
      "additionalProperties": true,
      "properties": {
        "backend": { "type": "string", "enum": ["claude", "codex", "gemini"] },
        "event": { "type": "string", "enum": ["started", "stopped", "config_reloaded", "credential_rotated"] },
        "detail": { "type": "string" }
      }
    },
    "ConversationTurn": {
      "type": "object",
      "required": ["session_id_hash", "role", "content_bytes"],
      "additionalProperties": true,
      "properties": {
        "session_id_hash": { "type": "string", "minLength": 12, "maxLength": 12 },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content_bytes": { "type": "integer", "minimum": 0 },
        "model": { "type": "string" }
      }
    },
    "ConversationChunk": {
      "type": "object",
      "required": ["session_id_hash", "role", "seq", "content", "final"],
      "additionalProperties": true,
      "properties": {
        "session_id_hash": { "type": "string", "minLength": 12, "maxLength": 12 },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "seq": { "type": "integer", "minimum": 0 },
        "content": { "type": "string" },
        "final": { "type": "boolean" }
      }
    },
    "ToolUse": {
      "type": "object",
      "required": ["session_id_hash", "tool", "duration_ms", "outcome"],
      "additionalProperties": true,
      "properties": {
        "session_id_hash": { "type": "string", "minLength": 12, "maxLength": 12 },
        "tool": { "type": "string" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "outcome": { "type": "string", "enum": ["ok", "error", "denied"] },
        "result_size_bytes": { "type": "integer", "minimum": 0 },
        "error": { "type": "string" }
      }
    },
    "TraceSpan": {
      "type": "object",
      "required": ["span_name", "duration_ms", "status", "service"],
      "additionalProperties": true,
      "properties": {
        "session_id_hash": { "type": "string", "minLength": 12, "maxLength": 12 },
        "span_name": { "type": "string" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "status": { "type": "string", "enum": ["ok", "error"] },
        "service": { "type": "string" }
      }
    },
    "StreamGap": {
      "type": "object",
      "required": ["last_seen_id", "resume_id"],
      "additionalProperties": true,
      "properties": {
        "last_seen_id": { "type": "string" },
        "resume_id": { "type": "string" },
        "reason": { "type": "string" }
      }
    },
    "StreamOverrun": {
      "type": "object",
      "required": ["queue_depth", "queue_max"],
      "additionalProperties": true,
      "properties": {
        "queue_depth": { "type": "integer", "minimum": 0 },
        "queue_max": { "type": "integer", "minimum": 0 },
        "reason": { "type": "string" }
      }
    }
  }
}
