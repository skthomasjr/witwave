# ww CLI build artifacts
/ww
/clients/ww/ww
/bin/
dist/

# Agent / audit scratch binaries — running `go build` without `-o` in any
# Go module dir dumps a binary named after the package (ww, operator, etc.)
# in the cwd. Ad-hoc test scratch files from audit agents (test_*_logic,
# test_*_scratch) also show up here. Keep them out of git.
/test_*_logic
/test_*_scratch
/scratch_*

# macOS
.DS_Store
.DS_store
.AppleDouble
.LSOverride
._*

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Python
__pycache__/
*.py[cod]
*.egg-info/
.env

# Local developer environment
mise.local.toml
mise.*.local.toml

# Node
node_modules/

# Logs
*.log

# Virtual environments
.venv/

# Agent runtime artifacts
*.jsonl
.checkpoints/
.claude/memory/
.claude/sessions/
.claude/session-env/
.claude/shell-snapshots/
.claude/projects/
.claude/plans/
.claude/backups/

# ww CLI release pipeline: transient LICENSE + install.sh copies +
# goreleaser dist/. Both files are copied into clients/ww/ by the
# goreleaser before-hooks so the workdir-local globs resolve cleanly.
clients/ww/LICENSE
clients/ww/install.sh
clients/ww/dist/
