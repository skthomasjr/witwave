{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "nyx chart values",
  "description": "First-pass values schema for the nyx Helm chart (#617). Permissive by design: additionalProperties is true everywhere so existing users' extra keys continue to render. Tightened iterations will narrow this over time.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "dashboard": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "port": { "type": ["integer", "string"] },
        "replicas": { "type": "integer", "minimum": 0 },
        "image": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string", "not": { "pattern": "^(latest|.*[:@]latest)$" } },
            "pullPolicy": { "type": "string" }
          }
        },
        "imagePullSecrets": { "type": "array" },
        "resources": { "type": "object" },
        "securityContext": { "type": "object" }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": { "type": "array" },
        "tls": { "type": "array" },
        "auth": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "type": { "type": "string", "enum": ["basic"] },
            "allowInsecure": { "type": "boolean" },
            "basic": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "existingSecret": { "type": "string" },
                "htpasswd": { "type": "string" },
                "realm": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "autoscaling": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 0 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 },
        "targetMemoryUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": ["integer", "string"] },
        "maxUnavailable": { "type": ["integer", "string"] }
      }
    },
    "terminationGracePeriodSeconds": { "type": "integer", "minimum": 0 },
    "preStop": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "delaySeconds": { "type": "integer", "minimum": 0 }
      }
    },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" },
    "topologySpreadConstraints": { "type": "array" },
    "priorityClassName": { "type": "string" },
    "probes": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "liveness": { "type": "object" },
        "readiness": { "type": "object" },
        "startup": { "type": "object" }
      }
    },
    "gitSync": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "image": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string", "not": { "pattern": "^(latest|.*[:@]latest)$" } }
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "serviceAnnotations": { "type": "boolean" },
        "podAnnotations": { "type": "boolean" }
      }
    },
    "serviceMonitor": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "scrapeInterval": { "type": "string" },
        "scrapeTimeout": { "type": "string" },
        "labels": { "type": "object" }
      }
    },
    "podMonitor": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "scrapeInterval": { "type": "string" },
        "scrapeTimeout": { "type": "string" },
        "labels": { "type": "object" }
      }
    },
    "observability": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "tracing": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "endpoint": { "type": "string" },
            "sampler": { "type": "string" },
            "samplerArg": { "type": "string" },
            "collector": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "enabled": { "type": "boolean" },
                "image": {
                  "type": "object",
                  "additionalProperties": true,
                  "properties": {
                    "repository": { "type": "string" },
                    "tag": { "type": "string", "not": { "pattern": "^(latest|.*[:@]latest)$" } },
                    "pullPolicy": { "type": "string" }
                  }
                },
                "replicas": { "type": "integer", "minimum": 0 },
                "service": {
                  "type": "object",
                  "additionalProperties": true,
                  "properties": {
                    "type": { "type": "string" },
                    "name": { "type": "string" }
                  }
                },
                "resources": { "type": "object" },
                "config": { "type": "object" }
              }
            }
          }
        }
      }
    },
    "sharedStorage": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "mountPath": { "type": "string" },
        "storageType": { "type": "string", "enum": ["pvc", "hostPath"] },
        "size": { "type": "string" },
        "storageClassName": { "type": "string" },
        "accessModes": { "type": "array", "items": { "type": "string" } },
        "existingClaim": { "type": "string" },
        "hostPath": { "type": "string" }
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "resources": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "harness": { "type": ["object", "null"] },
            "backend": { "type": ["object", "null"] },
            "backends": { "type": ["object", "null"] }
          }
        }
      }
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "port": { "type": ["integer", "string"] },
          "image": { "type": "object" },
          "imagePullSecrets": { "type": "array" },
          "nodeSelector": { "type": "object" },
          "tolerations": { "type": "array" },
          "affinity": { "type": "object" },
          "topologySpreadConstraints": { "type": "array" },
          "priorityClassName": { "type": "string" },
          "resources": { "type": "object" },
          "metrics": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "enabled": { "type": "boolean" },
              "serviceAnnotations": { "type": "boolean" },
              "podAnnotations": { "type": "boolean" }
            }
          },
          "gitSyncs": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["name", "repo"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "repo": { "type": "string", "minLength": 1 },
                "ref": { "type": "string" },
                "period": { "type": "string" },
                "depth": { "type": "integer", "minimum": 0 },
                "image": { "type": ["string", "object"] },
                "envFrom": { "type": "array" }
              }
            }
          },
          "gitMappings": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["gitSync", "src", "dest"],
              "properties": {
                "gitSync": { "type": "string", "minLength": 1 },
                "src": { "type": "string", "minLength": 1 },
                "dest": { "type": "string", "minLength": 1 }
              }
            }
          },
          "env": { "type": "array" },
          "envFrom": { "type": "array" },
          "config": { "type": "array" },
          "backends": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["name"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "enabled": { "type": "boolean" },
                "image": { "type": "object" },
                "port": { "type": ["integer", "string"] },
                "model": { "type": "string" },
                "resources": { "type": "object" },
                "env": { "type": "array" },
                "envFrom": { "type": "array" },
                "gitMappings": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true,
                    "required": ["gitSync", "src", "dest"],
                    "properties": {
                      "gitSync": { "type": "string", "minLength": 1 },
                      "src": { "type": "string", "minLength": 1 },
                      "dest": { "type": "string", "minLength": 1 }
                    }
                  }
                },
                "storage": {
                  "type": "object",
                  "additionalProperties": true,
                  "properties": {
                    "enabled": { "type": "boolean" },
                    "size": { "type": "string" },
                    "storageClassName": { "type": "string" },
                    "existingClaim": { "type": "string" },
                    "mounts": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": true,
                        "required": ["subPath", "mountPath"],
                        "properties": {
                          "subPath": { "type": "string", "minLength": 1 },
                          "mountPath": { "type": "string", "minLength": 1 }
                        }
                      }
                    }
                  }
                },
                "config": { "type": "array" }
              }
            }
          },
          "autoscaling": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "enabled": { "type": "boolean" },
              "minReplicas": { "type": "integer", "minimum": 0 },
              "maxReplicas": { "type": "integer", "minimum": 1 },
              "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 },
              "targetMemoryUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
            }
          },
          "podDisruptionBudget": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "enabled": { "type": "boolean" },
              "minAvailable": { "type": ["integer", "string"] },
              "maxUnavailable": { "type": ["integer", "string"] }
            }
          }
        }
      }
    }
  }
}
