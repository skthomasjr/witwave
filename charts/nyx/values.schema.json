{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "nyx chart values",
  "description": "First-pass values schema for the nyx Helm chart (#617). Permissive by design: additionalProperties is true everywhere so existing users' extra keys continue to render. Tightened iterations will narrow this over time.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "dashboard": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "port": { "type": ["integer", "string"] },
        "replicas": { "type": "integer", "minimum": 0 },
        "image": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string", "not": { "pattern": "^(latest|.*[:@]latest)$" } },
            "pullPolicy": { "type": "string" }
          }
        },
        "imagePullSecrets": { "type": "array" },
        "resources": { "type": "object" },
        "securityContext": { "type": "object" }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": { "type": "array" },
        "tls": { "type": "array" },
        "auth": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "type": { "type": "string", "enum": ["basic"] },
            "allowInsecure": { "type": "boolean" },
            "basic": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "existingSecret": { "type": "string" },
                "htpasswd": { "type": "string" },
                "realm": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "autoscaling": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 0 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 },
        "targetMemoryUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": ["integer", "string"] },
        "maxUnavailable": { "type": ["integer", "string"] }
      }
    },
    "terminationGracePeriodSeconds": { "type": "integer", "minimum": 0 },
    "preStop": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "delaySeconds": { "type": "integer", "minimum": 0 }
      }
    },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" },
    "topologySpreadConstraints": { "type": "array" },
    "priorityClassName": { "type": "string" },
    "probes": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "liveness": { "type": "object" },
        "readiness": { "type": "object" },
        "startup": { "type": "object" }
      }
    },
    "gitSync": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "image": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string", "not": { "pattern": "^(latest|.*[:@]latest)$" } }
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "serviceAnnotations": { "type": "boolean" },
        "podAnnotations": { "type": "boolean" }
      }
    },
    "serviceMonitor": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "scrapeInterval": { "type": "string" },
        "scrapeTimeout": { "type": "string" },
        "labels": { "type": "object" },
        "sampleLimit": { "type": ["integer", "null"], "minimum": 0 },
        "targetLimit": { "type": ["integer", "null"], "minimum": 0 },
        "labelValueLengthLimit": { "type": ["integer", "null"], "minimum": 0 },
        "metricRelabelings": { "type": "array" }
      }
    },
    "podMonitor": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "scrapeInterval": { "type": "string" },
        "scrapeTimeout": { "type": "string" },
        "labels": { "type": "object" },
        "sampleLimit": { "type": ["integer", "null"], "minimum": 0 },
        "targetLimit": { "type": ["integer", "null"], "minimum": 0 },
        "labelValueLengthLimit": { "type": ["integer", "null"], "minimum": 0 },
        "metricRelabelings": { "type": "array" }
      }
    },
    "serviceMesh": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "type": { "type": "string", "enum": ["linkerd", "istio", "none"] }
      }
    },
    "prometheusRule": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "additionalLabels": { "type": "object" },
        "alerts": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "grafanaDashboards": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "label": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "additionalLabels": { "type": "object" },
        "annotations": { "type": "object" }
      }
    },
    "vpa": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "updateMode": { "type": "string", "enum": ["Off", "Initial", "Recreate", "Auto"] },
        "minReplicas": { "type": ["integer", "string"] },
        "resourcePolicy": { "type": "object" }
      }
    },
    "observability": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "tracing": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "endpoint": { "type": "string" },
            "sampler": { "type": "string" },
            "samplerArg": { "type": "string" },
            "collector": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "enabled": { "type": "boolean" },
                "image": {
                  "type": "object",
                  "additionalProperties": true,
                  "properties": {
                    "repository": { "type": "string" },
                    "tag": { "type": "string", "not": { "pattern": "^(latest|.*[:@]latest)$" } },
                    "pullPolicy": { "type": "string" }
                  }
                },
                "replicas": { "type": "integer", "minimum": 0 },
                "service": {
                  "type": "object",
                  "additionalProperties": true,
                  "properties": {
                    "type": { "type": "string" },
                    "name": { "type": "string" }
                  }
                },
                "resources": { "type": "object" },
                "config": { "type": "object" }
              }
            }
          }
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "ingress": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "allowDashboard": { "type": "boolean" },
            "allowSameNamespace": { "type": "boolean" },
            "allowNyxAgents": { "type": "boolean" },
            "metricsFrom": { "type": "array" },
            "additionalFrom": { "type": "array" }
          }
        },
        "egressOpen": { "type": "boolean" },
        "egress": { "type": "array" }
      }
    },
    "sharedStorage": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "mountPath": { "type": "string" },
        "storageType": { "type": "string", "enum": ["pvc", "hostPath"] },
        "size": { "type": "string" },
        "storageClassName": { "type": "string" },
        "accessModes": { "type": "array", "items": { "type": "string" } },
        "existingClaim": { "type": "string" },
        "hostPath": { "type": "string" }
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "resources": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "harness": { "type": ["object", "null"] },
            "backend": { "type": ["object", "null"] },
            "backends": { "type": ["object", "null"] }
          }
        }
      }
    },
    "mcpTools": {
      "$comment": "MCP tool servers opted in per-tool (#954). additionalProperties:false at the tool level catches typos like `kubernates.enabled` that would otherwise pass validation, deploy silently, and only surface as a runtime 404/500 from the backend → MCP hop.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "metricsPort": { "type": ["integer", "string"] },
        "kubernetes": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "automountServiceAccountToken": { "type": "boolean" },
            "image": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "repository": { "type": "string" },
                "tag": { "type": "string" },
                "digest": { "type": "string" },
                "pullPolicy": { "type": "string" }
              }
            },
            "replicas": { "type": ["integer", "string"] },
            "serviceAccountName": { "type": "string" },
            "imagePullSecrets": { "type": "array" },
            "resources": { "type": "object" },
            "env": { "type": "array" },
            "envFrom": { "type": "array" },
            "nodeSelector": { "type": "object" },
            "tolerations": { "type": "array" },
            "affinity": { "type": "object" },
            "topologySpreadConstraints": { "type": "array" },
            "priorityClassName": { "type": "string" },
            "probes": { "type": "object" },
            "rbac": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "create": { "type": "boolean" },
                "clusterWide": { "type": "boolean" },
                "rules": { "type": "array" }
              }
            }
          }
        },
        "helm": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "automountServiceAccountToken": { "type": "boolean" },
            "image": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "repository": { "type": "string" },
                "tag": { "type": "string" },
                "digest": { "type": "string" },
                "pullPolicy": { "type": "string" }
              }
            },
            "replicas": { "type": ["integer", "string"] },
            "serviceAccountName": { "type": "string" },
            "imagePullSecrets": { "type": "array" },
            "resources": { "type": "object" },
            "env": { "type": "array" },
            "envFrom": { "type": "array" },
            "nodeSelector": { "type": "object" },
            "tolerations": { "type": "array" },
            "affinity": { "type": "object" },
            "topologySpreadConstraints": { "type": "array" },
            "priorityClassName": { "type": "string" },
            "probes": { "type": "object" },
            "rbac": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "create": { "type": "boolean" },
                "clusterWide": { "type": "boolean" },
                "rules": { "type": "array" }
              }
            }
          }
        },
        "prometheus": {
          "$comment": "mcp-prometheus (#853): PromQL query surface for agents. Grafana/Loki/OTel wrappers are follow-ups.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "automountServiceAccountToken": { "type": "boolean" },
            "image": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "repository": { "type": "string" },
                "tag": { "type": "string" },
                "digest": { "type": "string" },
                "pullPolicy": { "type": "string" }
              }
            },
            "replicas": { "type": ["integer", "string"] },
            "serviceAccountName": { "type": "string" },
            "imagePullSecrets": { "type": "array" },
            "resources": { "type": "object" },
            "env": { "type": "array" },
            "envFrom": { "type": "array" },
            "nodeSelector": { "type": "object" },
            "tolerations": { "type": "array" },
            "affinity": { "type": "object" },
            "topologySpreadConstraints": { "type": "array" },
            "priorityClassName": { "type": "string" },
            "probes": { "type": "object" },
            "rbac": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "create": { "type": "boolean" },
                "clusterWide": { "type": "boolean" },
                "rules": { "type": "array" }
              }
            }
          }
        }
      }
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["name"],
        "properties": {
          "name": {
            "$comment": "DNS-1123 label (#1023). Agent name becomes part of Pod, Service, and ConfigMap names — uppercase or underscored names pass schema but fail at K8s admission with an unhelpful message. Enforce the shape here.",
            "type": "string",
            "minLength": 1,
            "maxLength": 63,
            "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
          },
          "port": { "type": ["integer", "string"] },
          "image": { "type": "object" },
          "imagePullSecrets": { "type": "array" },
          "nodeSelector": { "type": "object" },
          "tolerations": { "type": "array" },
          "affinity": { "type": "object" },
          "topologySpreadConstraints": { "type": "array" },
          "priorityClassName": { "type": "string" },
          "resources": { "type": "object" },
          "metrics": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "enabled": { "type": "boolean" },
              "serviceAnnotations": { "type": "boolean" },
              "podAnnotations": { "type": "boolean" }
            }
          },
          "gitSyncs": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["name", "repo"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "repo": { "type": "string", "minLength": 1 },
                "ref": { "type": "string" },
                "period": { "type": "string" },
                "depth": { "type": "integer", "minimum": 0 },
                "image": { "type": ["string", "object"] },
                "envFrom": { "type": "array" }
              }
            }
          },
          "gitMappings": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["gitSync", "src", "dest"],
              "properties": {
                "gitSync": { "type": "string", "minLength": 1 },
                "src": { "type": "string", "minLength": 1 },
                "dest": { "type": "string", "minLength": 1 }
              }
            }
          },
          "env": { "type": "array" },
          "envFrom": { "type": "array" },
          "config": { "type": "array" },
          "backends": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["name"],
              "properties": {
                "name": {
                  "$comment": "DNS-1123 label (#1023). Backend name embeds into Service/PVC/ConfigMap names so it must match the label regex Kubernetes enforces at admission.",
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 63,
                  "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
                },
                "enabled": { "type": "boolean" },
                "image": { "type": "object" },
                "port": { "type": ["integer", "string"] },
                "model": { "type": "string" },
                "resources": { "type": "object" },
                "env": { "type": "array" },
                "envFrom": { "type": "array" },
                "credentials": {
                  "type": "object",
                  "additionalProperties": true,
                  "properties": {
                    "secretName": { "type": "string" },
                    "secretRef": {
                      "type": "object",
                      "additionalProperties": true,
                      "properties": {
                        "name": { "type": "string" }
                      }
                    },
                    "keys": { "type": "array", "items": { "type": "string" } }
                  }
                },
                "gitMappings": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true,
                    "required": ["gitSync", "src", "dest"],
                    "properties": {
                      "gitSync": { "type": "string", "minLength": 1 },
                      "src": { "type": "string", "minLength": 1 },
                      "dest": { "type": "string", "minLength": 1 }
                    }
                  }
                },
                "storage": {
                  "type": "object",
                  "additionalProperties": true,
                  "properties": {
                    "enabled": { "type": "boolean" },
                    "size": { "type": "string" },
                    "storageClassName": { "type": "string" },
                    "existingClaim": { "type": "string" },
                    "mounts": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": true,
                        "required": ["subPath", "mountPath"],
                        "properties": {
                          "subPath": { "type": "string", "minLength": 1 },
                          "mountPath": { "type": "string", "minLength": 1 }
                        }
                      }
                    }
                  }
                },
                "config": { "type": "array" }
              }
            }
          },
          "autoscaling": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "enabled": { "type": "boolean" },
              "minReplicas": { "type": "integer", "minimum": 0 },
              "maxReplicas": { "type": "integer", "minimum": 1 },
              "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 },
              "targetMemoryUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
            }
          },
          "podDisruptionBudget": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "enabled": { "type": "boolean" },
              "minAvailable": { "type": ["integer", "string"] },
              "maxUnavailable": { "type": ["integer", "string"] }
            }
          }
        }
      }
    },
    "certManager": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "issuer": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "name": { "type": "string" },
            "kind": { "type": "string" }
          }
        }
      }
    },
    "cors": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "allowOrigins": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "allowWildcard": { "type": "boolean" }
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "className": { "type": ["string", "null"] },
        "size": { "type": "string" },
        "accessModes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "mcpTools": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "metricsPort": { "type": ["integer", "string"] }
      },
      "patternProperties": {
        "^[a-z][a-z0-9-]*$": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "image": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "repository": { "type": "string" },
                "tag": { "type": "string", "not": { "pattern": "^(latest|.*[:@]latest)$" } },
                "pullPolicy": { "type": "string" }
              }
            },
            "replicas": { "type": "integer", "minimum": 0 },
            "resources": { "type": "object" },
            "securityContext": { "type": "object" },
            "serviceAccountName": { "type": "string" },
            "automountServiceAccountToken": { "type": ["boolean", "null"] },
            "env": { "type": "array" },
            "envFrom": { "type": "array" },
            "rbac": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "create": { "type": "boolean" },
                "clusterWide": { "type": "boolean" },
                "rules": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "apiGroups": { "type": "array", "items": { "type": "string" } },
                      "resources": { "type": "array", "items": { "type": "string" } },
                      "resourceNames": { "type": "array", "items": { "type": "string" } },
                      "verbs": { "type": "array", "items": { "type": "string" } },
                      "nonResourceURLs": { "type": "array", "items": { "type": "string" } }
                    },
                    "required": ["verbs"]
                  }
                }
              }
            },
            "networkPolicy": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "enabled": { "type": "boolean" },
                "egress": { "type": "string" },
                "allowNamespaces": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        }
      }
    }
  }
}
