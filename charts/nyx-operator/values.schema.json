{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "nyx-operator chart values",
  "description": "First-pass values schema for the nyx-operator Helm chart (#617). Permissive by design: additionalProperties is true everywhere so existing users' extra keys continue to render.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "image": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string" }
      }
    },
    "imagePullSecrets": { "type": "array" },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "replicaCount": { "type": "integer", "minimum": 0 },
    "installCRDs": { "type": "boolean" },
    "rbac": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "create": { "type": "boolean" },
        "scope": { "type": "string", "enum": ["cluster", "namespace"] },
        "watchNamespaces": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "leaderElection": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "port": { "type": ["integer", "string"] },
        "secure": { "type": "boolean" }
      }
    },
    "serviceMonitor": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "scrapeInterval": { "type": "string" },
        "scrapeTimeout": { "type": "string" },
        "labels": { "type": "object" },
        "tlsConfig": { "type": "object" }
      }
    },
    "probes": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "port": { "type": ["integer", "string"] }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": ["integer", "string"] },
        "maxUnavailable": { "type": ["integer", "string"] }
      }
    },
    "terminationGracePeriodSeconds": { "type": "integer", "minimum": 0 },
    "preStop": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "delaySeconds": { "type": "integer", "minimum": 0 }
      }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "create": { "type": "boolean" },
        "automount": { "type": "boolean" },
        "annotations": { "type": "object" },
        "name": { "type": "string" }
      }
    },
    "podAnnotations": { "type": "object" },
    "podLabels": { "type": "object" },
    "podSecurityContext": { "type": "object" },
    "securityContext": { "type": "object" },
    "resources": { "type": "object" },
    "extraArgs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "env": { "type": "array" },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" }
  }
}
